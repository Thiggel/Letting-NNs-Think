srun python -m experiment \
  --model-name "meta-llama/Llama-3.1-8B" \
  --pretrained \
  --use-gating \
  --skip-modules \
  --skip-layers \
  --eval-batch-size 32 \
  --seq-length 4096 \
  --finetune-mode full \
  --mode evaluate \
  --evaluation-metrics commonsense_qa,piqa,mmlu_stem,hellaswag \
  --num-fewshot 0 \
  --experiment-name llama8b_vector_individual_gate \
  --load-from-checkpoint llama8b-csqa-gsm8k-gen-individual \
  --project-name gateskip
