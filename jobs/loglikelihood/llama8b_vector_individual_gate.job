#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=32
#SBATCH --mem=368640
#SBATCH --ntasks-per-node=1
#SBATCH --time=72:00:00
#SBATCH --job-name=llama8b_vector_individual_gate
#SBATCH --output=job_logs/loglikelihood/llama8b_vector_individual_gate-%A.out

cd $HOME/Gating

. jobs/environment.sh

