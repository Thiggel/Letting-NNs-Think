srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --pretrained \
  --use-early-exit \
  --confidence-measure hidden_state \
  --eval-batch-size 128 \
  --seq-length 4096 \
  --finetune-mode full \
  --mode evaluate \
  --evaluation-metrics commonsense_qa,piqa,mmlu_stem,hellaswag \
  --num-fewshot 0 \
  --experiment-name llama1b_calm \
  --load-from-checkpoint llama1b-csqa-gsm8k-early-exit \
  --project-name gateskip

srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --pretrained \
  --use-early-exit \
  --confidence-measure softmax \
  --eval-batch-size 128 \
  --seq-length 4096 \
  --finetune-mode full \
  --mode evaluate \
  --evaluation-metrics commonsense_qa,piqa,mmlu_stem,hellaswag \
  --num-fewshot 0 \
  --experiment-name llama1b_calm \
  --load-from-checkpoint llama1b-csqa-gsm8k-early-exit \
  --project-name gateskip

