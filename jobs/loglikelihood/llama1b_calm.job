#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --ntasks-per-node=1
#SBATCH --time=04:30:00
#SBATCH --job-name=loglikelihood_llama1b_calm
#SBATCH --output=job_logs/loglikelihood/llama1b_calm-%A.out

cd $HOME/Gating

. jobs/environment.sh

srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --dataset fineweb \
  --max-hours 1 \
  --pretrained \
  --use-early-exit \
  --batch-size 1 \
  --eval-batch-size 1 \
  --seq-length 1024 \
  --learning-rate 3e-6 \
  --warmup-steps 1000 \
  --lr-decay-steps 6800 \
  --max-epochs 1 \
  --finetune-mode full \
  --experiment-name loglikelihood_llama1b_calm \
  --save-to-checkpoint loglikelihood_llama1b_calm \
  --project-name gateskip \
  --enable-logging
 
srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --pretrained \
  --use-early-exit \
  --confidence-measure hidden_state \
  --eval-batch-size 128 \
  --seq-length 1024 \
  --finetune-mode full \
  --mode evaluate \
  --evaluation-metrics commonsense_qa,piqa,mmlu_stem,hellaswag,winogrande,openbookqa \
  --num-fewshot 5 \
  --experiment-name loglikelihood_llama1b_calm_hss \
  --load-from-checkpoint loglikelihood_llama1b_calm \
  --project-name gateskip

srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --pretrained \
  --use-early-exit \
  --confidence-measure softmax \
  --eval-batch-size 128 \
  --seq-length 1024 \
  --finetune-mode full \
  --mode evaluate \
  --evaluation-metrics commonsense_qa,piqa,mmlu_stem,hellaswag,winogrande,openbookqa \
  --num-fewshot 5 \
  --experiment-name loglikelihood_llama1b_calm_softmax \
  --load-from-checkpoint loglikelihood_llama1b_calm \
  --project-name gateskip

