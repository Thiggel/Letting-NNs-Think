#   --project-name gateskip \
#   --enable-logging
 
srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --pretrained \
  --use-mod \
  --mod-capacity-factor 0.8 \
  --skip-threshold 0.0 \
  --eval-batch-size 128 \
  --seq-length 4096 \
  --finetune-mode full \
  --mode evaluate \
  --evaluation-metrics csqa_gen,gsm8k,piqa_gen \
  --num-fewshot 0 \
  --experiment-name llama1b_mod \
  --load-from-checkpoint llama1b-csqa-gsm8k-mod \
  --project-name gateskip

