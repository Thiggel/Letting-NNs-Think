srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --pretrained \
  --use-gating \
  --skip-modules \
  --skip-layers \
  --eval-batch-size 64 \
  --seq-length 4096 \
  --finetune-mode full \
  --mode evaluate \
 --evaluation-metrics wmt_gen \
  --num-fewshot 0 \
  --experiment-name llama1b_vector_individual_gate_wmt \
  --load-from-checkpoint llama1b_vector_individual_gate_wmt \
  --project-name gateskip
