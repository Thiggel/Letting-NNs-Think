 --model-name "meta-llama/Llama-3.2-1B" \
 --pretrained \
 --use-gating \
 --skip-entire-layer-based-on-attn \
 --eval-batch-size 100 \
 --seq-length 4096 \
 --finetune-mode full \
 --mode evaluate \
 --evaluation-metrics wmt-gen \
 --num-fewshot 0 \
 --experiment-name llama1b-wmt16-individual-0.7125 \
 --load-from-checkpoint llama1b-wmt16-individual \
 --skip-modules \
 --skip-threshold 0.7125 \
 --project-name skipgate \
 --enable-logging

