#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --ntasks-per-node=1
#SBATCH --time=8:30:00
#SBATCH --job-name=llama-1b-WMT
#SBATCH --output=job_logs/llama-1b/wmt16/individual-%A.out

cd $HOME/Gating

. jobs/environment.sh

