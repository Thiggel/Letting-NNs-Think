  --always-skip-layers 12 13 14 \
  --eval-batch-size 200 \
  --seq-length 4096 \
  --finetune-mode full \
  --mode evaluate \
 --evaluation-metrics wmt-gen \
  --num-fewshot 0 \
  --experiment-name llama1b-wmt-16-baseline-alwaysskip-13-14-15 \
