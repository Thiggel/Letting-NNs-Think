#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --ntasks-per-node=1
#SBATCH --time=8:30:00
#SBATCH --job-name=Shared-Gates-CSQAGen
#SBATCH --output=job_logs/Shared-Gates-CSQAGen-%A.out

cd $HOME/Gating

. jobs/environment.sh

