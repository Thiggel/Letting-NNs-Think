srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --dataset csqa_gen \
  --pretrained \
  --batch-size 8 \
  --eval-batch-size 16 \
  --seq-length 1024 \
  --learning-rate 3e-6 \
  --warmup-steps 1000 \
  --max-epochs 15 \
  --use-early-stopping \
  --max-hours 5 \
  --finetune-mode full \
  --use-deepspeed \
  --experiment-name LLama-1b-CSQAGen_3e6 \
  --save-to-checkpoint Llama_1b_CSQAGen_3e6 \
  --project-name gating \
  --enable-logging


