#!/bin/bash

#SBATCH -C A5000
#SBATCH --gres=gpu:4
#SBATCH --job-name=GSM8K_7Steps_TimeEmbedding_Eval
#SBATCH --ntasks-per-node=4
#SBATCH --time=72:00:00
#SBATCH --output=job_logs/GSM8K_7Steps_TimeEmbedding_Eval_%A.out

cd $HOME/Letting-NNs-Think

. jobs/environment.sh

srun python -m experiment \
  --model-name "google/gemma-2-2b" \
  --make-layers-recurrent 11 \
  --use-time-embedding \
  --num-steps 7 \
  --mode evaluate \
  --evaluation-metrics gsm8k \
  --load-from-checkpoint GSM8K_7Step_TimeEmbedding \
  --enable-logging \
  --experiment-name GSM8K_7Step_TimeEmbedding
