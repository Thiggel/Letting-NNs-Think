#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --job-name=GSM8K_10Steps_DynamicVera
#SBATCH --ntasks-per-node=1
#SBATCH --time=4:00:00
#SBATCH --output=job_logs/GSM8K_10Steps_DynamicVera_%A.out

cd $HOME/Letting-NNs-Think

. jobs/environment.sh

srun python -m experiment \
  --model-name "google/gemma-2-2b" \
  --dataset gsm8k \
  --use-dynamic-vera \
  --make-layers-recurrent -1 \
  --num-steps 10 \
  --batch-size 8 \
  --experiment-name GSM8K_10Step_DynamicVera \
  --enable-logging \
  --save-to-checkpoint GSM8K_10Step_DynamicVera

srun python -m experiment \
  --model-name "google/gemma-2-2b" \
  --make-layers-recurrent -1 \
  --use-dynamic-vera \
  --num-steps 10 \
  --mode evaluate \
  --evaluation-metrics gsm8k \
  --load-from-checkpoint GSM8K_10Step_DynamicVera \
  --enable-logging \
  --experiment-name GSM8K_10Step_DynamicVera
