#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --job-name=GSM8K_20Steps
#SBATCH --ntasks-per-node=1
#SBATCH --time4:00:00
#SBATCH --output=job_logs/GSM8K_20Steps_%A.out

cd $HOME/Letting-NNs-Think

. jobs/environment.sh

srun python -m experiment \
  --model-name "google/gemma-2-2b" \
  --dataset gsm8k \
  --make-layers-recurrent -1 \
  --num-steps 20 \
  --batch-size 8 \
  --experiment-name GSM8K_20Step \
  --save-to-checkpoint GSM8K_20Step \
  --enable-logging

srun python -m experiment \
  --model-name "google/gemma-2-2b" \
  --make-layers-recurrent -1 \
  --num-steps 20 \
  --mode evaluate \
  --evaluation-metrics gsm8k \
  --load-from-checkpoint GSM8K_20Step \
  --experiment-name GSM8K_20Step \
  --enable-logging
