#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --ntasks-per-node=1
#SBATCH --time=4:00:00
#SBATCH --job-name=Projection-Frozen-1e-3
#SBATCH --output=job_logs/projection-frozen-1e-3-%A.out

cd $HOME/Letting-NNs-Think

. jobs/environment.sh

srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --dataset fineweb \
  --pretrained \
  --batch-size 1 \
  --seq-length 450 \
  --learning-rate 1e-3 \
  --warmup-steps 5000 \
  --max-epochs 10 \
  --max-training-steps 50000 \
  --uninterrupted-mode projection \
  --uninterrupted-recurrence-depth 5 \
  --finetune-mode frozen \
  --experiment-name ProjectionFrozenFineweb1e3 \
  --save-to-checkpoint ProjectionFrozenFineweb1e3 \
  --enable-logging
