#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --ntasks-per-node=1
#SBATCH --time=8:30:00
#SBATCH --job-name=Baseline-ComplexArithmetic-1e-5
#SBATCH --output=job_logs/baseline-complex-arithmetic-3e-5-%A.out

cd $HOME/Letting-NNs-Think

. jobs/environment.sh

srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --dataset complex_arithmetic_reasoning \
  --pretrained \
  --batch-size 64 \
  --eval-batch-size 64 \
  --seq-length 1024 \
  --learning-rate 1e-5 \
  --warmup-steps 300 \
  --max-epochs 1 \
  --max-hours 5 \
  --num-runs 3 \
  --seeds 42 43 44 \
  --max-training-steps 1000 \
  --validate-every-n-steps 500 \
  --finetune-mode full \
  --experiment-name Baseline_ComplexArithmetic_1e5 \
  --save-to-checkpoint Baseline_ComplexArithmetic_1e5 \
  --project-name uninterrupted-transformers \
  --enable-logging

srun python -m experiment \
  --model-name "meta-llama/Llama-3.2-1B" \
  --dataset complex_arithmetic_reasoning \
  --pretrained \
  --finetune-mode full \
  --eval-batch-size 128 \
  --seq-length 1024 \
  --num-runs 3 \
  --seeds 42 43 44 \
  --learning-rate 1e-5 \
  --evaluation-metrics complex_arithmetic_reasoning \
  --mode evaluate \
  --experiment-name Baseline_ComplexArithmetic_1e5_Eval \
  --load-from-checkpoint Baseline_ComplexArithmetic_1e5 \
  --project-name uninterrupted-transformers \
  --enable-logging
