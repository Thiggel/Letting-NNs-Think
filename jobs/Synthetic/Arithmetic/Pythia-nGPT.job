#!/bin/bash
#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --ntasks-per-node=1
#SBATCH --job-name=Pythia_Arithmetic_nGPT
#SBATCH --time=04:30:00
#SBATCH --output=job_logs/Pythia_Arithmetic_nGPT_%A.out

cd $HOME/Letting-NNs-Think
. jobs/environment.sh

srun python -m experiment \
    --model-name "EleutherAI/pythia-70m" \
    --dataset synthetic_arithmetic_task \
    --pretrained true \
    --finetune-mode full \
    --enable-normalization \
    --batch-size 64 \
    --grad-acc-steps 4 \
    --learning-rate 3e-4 \
    --warmup-steps 20000 \
    --max-training-steps 4000000 \
    --max-hours 4 \
    --experiment-name Pythia_Arithmetic_nGPT \
    --save-to-checkpoint Pythia_Arithmetic_nGPT \
    --enable-logging \
    --mode train

srun python -m experiment \
    --model-name "EleutherAI/pythia-70m" \
    --dataset synthetic_arithmetic_task \
    --pretrained true \
    --finetune-mode full \
    --enable-normalization \
    --experiment-name Pythia_Arithmetic_nGPT_Eval \
    --load-from-checkpoint Pythia_Arithmetic_nGPT \
    --evaluation-metrics arithmetic_task \
    --mode evaluate \
    --eval-batch-size 32 \
    --enable-logging
