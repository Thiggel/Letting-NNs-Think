run python -m experiment \
  --model-name "meta-llama/Llama-3.1-8B" \
 --pretrained \
 --use-gating \
  --skip-entire-layer-based-on-attn \
 --eval-batch-size 64 \
 --seq-length 4096 \
 --finetune-mode full \
 --mode evaluate \
 --evaluation-metrics csqa_gen,gsm8k,piqa_gen \
 --num-fewshot 0 \
 --experiment-name llama8b-csqa-gsm8k-gen-individual-0.0 \
 --load-from-checkpoint llama8b-csqa-gsm8k-gen-individual \
 --skip-modules \
 --skip-threshold 0.0 \
 --project-name skipgate \
 --enable-logging


srun python -m experiment \
  --model-name "meta-llama/Llama-3.1-8B" \
