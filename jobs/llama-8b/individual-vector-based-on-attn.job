#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --ntasks-per-node=1
#SBATCH --time=8:30:00
#SBATCH --job-name=llama-8b-GSM8K
#SBATCH --output=job_logs/llama-8b/csqa_gsm8k_gen/individual-%A.out

cd $HOME/Gating

. jobs/environment.sh

#srun python -m experiment \
